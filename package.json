{
  "name": "vicpol-cad",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "npm run dev --workspace=server",
    "dev:web": "npm run dev --workspace=web",
    "build": "npm run build --workspace=web",
    "start": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "overrides": {
    "undici": "^6.23.0",
    "discord.js": {
      "undici": "^6.23.0"
    },
    "@discordjs/rest": {
      "undici": "^6.23.0"
    }
  }
}
